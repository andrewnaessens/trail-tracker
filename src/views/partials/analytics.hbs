<div class="box">
  <h2 class="title is-5">User Analytics:</h2>
  <div class="columns">
    <div class="column is-3">
      <table class="table">
        <thead>
          <tr>
            <th>Categories</th>
          </tr>
        </thead>
        <tbody>
          {{#each categories}}
            <tr>
              <td>
                {{title}}
              </td>
            </tr>
          {{/each}}
          <tr>
              <td>
                <p>No. of Categories: {{categoryCount}}</p>
              </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="column is-3">
      <table class="table">
        <thead>
          <tr>
            <th>Trails</th>
          </tr>
        </thead>
        <tbody>
          {{#each trails}}
            <tr>
              <td>
                {{title}}
              </td>
            </tr>
          {{/each}}
          <tr>
              <td>
                <p>No. of Trails: {{trailCount}}</p>
              </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
