{
  "name": "trailtracker-ts",
  "version": "1.1.0",
  "description": "A hiking trail web application.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/views dist/public && cp -R src/views/* dist/views/ && cp -R public/* dist/public/",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "./node_modules/.bin/eslint . --ext .js",
    "test": "./node_modules/mocha/bin/_mocha --ui tdd test/**/*.js -exit",
    "testmodels": "./node_modules/mocha/bin/_mocha --ui tdd test/models/**/*.js -exit",
    "testapi": "./node_modules/mocha/bin/_mocha --ui tdd test/api/**/*.js -exit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewnaessens/trailtracker.git"
  },
  "keywords": [
    "node",
    "hapi"
  ],
  "author": "andrewnaessens",
  "license": "ISC",
  "homepage": "https://github.com/andrewnaessens/trail-tracker#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/cookie": "^12.0.1",
    "@hapi/hapi": "^21.4.3",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "hapi-auth-jwt2": "^11.0.0",
    "hapi-swagger": "^17.3.2",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^7.0.1",
    "mais-mongoose-seeder": "^1.0.7",
    "mongoose": "^8.19.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/hapi__cookie": "^12.0.5",
    "@types/hapi-auth-jwt2": "^8.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "axios": "^1.13.1",
    "chai": "^6.2.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "mocha": "^11.3.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
